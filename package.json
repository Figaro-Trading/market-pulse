{
  "name": "market-pulse",
  "version": "0.1.0",
  "description": "Trader-oriented financial news site backend. Aggregates news (Finnhub + Alpha Vantage) and live market events (crypto liquidations, quotes, funding/OI) over public APIs, no proprietary backend.",
  "keywords": [
    "finance",
    "trading",
    "news",
    "crypto",
    "liquidations",
    "funding-rate",
    "open-interest",
    "binance",
    "bybit",
    "bitmex",
    "finnhub",
    "alpha-vantage"
  ],
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "LOG_LEVEL=silent node --test 'test/**/*.test.js'",
    "lint": "eslint ."
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.1",
    "helmet": "8.1.0",
    "node-cron": "4.2.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.2",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "pino-pretty": "13.1.3",
    "supertest": "^7.0.0"
  },
  "license": "AGPL-3.0-or-later"
}
