# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info                          # trace|debug|info|warn|error

# Honor X-Forwarded-* for client IP (used by the rate limiter). Set ONLY when
# the service is fronted by a trusted reverse proxy — otherwise a client can
# spoof X-Forwarded-For and bypass per-IP limits. Examples: 1 (one hop),
# 'loopback', or a CIDR. Leave empty when binding directly to the public net.
TRUST_PROXY=

# Per-IP cap on /api/quote/* requests (each miss fans out to Yahoo/Nasdaq/
# Coinbase). Default 30/min keeps a tab usable while bounding amplification.
QUOTE_RATE_LIMIT=30

# ── News providers (Phase 2) ─────────────────────────────────────────────────
# Get free keys at https://finnhub.io/register and
# https://www.alphavantage.co/support/#api-key
FINNHUB_KEY=
ALPHAVANTAGE_KEY=

# Cron expression for the news refresh job.
# Default = every 30 min — fits Finnhub free tier (4 categories × 48 = 192 req/day)
# and Alpha Vantage free tier (25 req/day; AV is rate-limited internally to 1/h).
NEWS_REFRESH_CRON=*/30 * * * *

# Categories pulled from Finnhub on each refresh.
FINNHUB_CATEGORIES=general,forex,crypto,merger

# How often Alpha Vantage runs (in cron-runs). 1 = every refresh, 2 = every other, …
# With NEWS_REFRESH_CRON=*/30 and AV_RUN_EVERY=2, AV is hit once per hour.
AV_RUN_EVERY=2

# ── Liquidations (Phase 3) ───────────────────────────────────────────────────
LIQ_MIN_NOTIONAL_USD=1000000            # default threshold for /api/liquidations (1M USD)
LIQ_BUFFER_SIZE=50000                   # in-memory ring buffer capacity
LIQ_EXCHANGES=binance,bybit,bitmex      # comma-separated subset to enable
LIQ_BINANCE_COIN_M=true                 # also subscribe to Binance COIN-M (dstream); set false to skip
# Bybit V5 has no firehose for liquidations — we subscribe per symbol.
# If unset, default = top 30 active linear perps. Override with a comma list.
# LIQ_BYBIT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# ── Quotes (Phase 5) ─────────────────────────────────────────────────────────
QUOTE_CACHE_TTL_MS=10000                # per-symbol TTL

# ── Derivatives — Bybit funding & open interest (Phase 6) ───────────────────
DERIV_REFRESH_MS=300000                 # refresh funding & OI every 5 min
DERIV_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT   # symbols to track (Bybit perp linear)

# ── Operations ───────────────────────────────────────────────────────────────
# Bearer token required for POST /api/news/refresh. If unset, the endpoint
# returns 503 (disabled) — recommended posture in production unless you
# explicitly need the manual trigger. Generate with: openssl rand -hex 32
NEWS_REFRESH_TOKEN=
